{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "assets/**",
          "banners/**",
          "seo-generator.js",
          "seo-data.json",
          "*.html",
          "*.jpg",
          "*.png",
          "*.xml",
          "*.svg",
          "*.txt"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
